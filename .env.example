PINGCODE_BASE_URL=https://your-domain.pingcode.com
# Public SaaS uses https://open.pingcode.com. Private deployments may use https://your-domain/open.
PINGCODE_API_BASE_URL=https://open.pingcode.com

# Recommended for shared MCP usage: create a PingCode app with Client Credentials.
PINGCODE_CLIENT_ID=
PINGCODE_CLIENT_SECRET=

# Optional fallback: official PingCode Open API access token.
# Do not paste browser cookies or encrypted localStorage values here.
PINGCODE_ACCESS_TOKEN=
PINGCODE_AUTH_SCHEME=Bearer

PINGCODE_PROJECT_IDENTIFIER=PROJECT_KEY
PINGCODE_PROJECT_ID=

# Each user should set this to their own PingCode display name.
PINGCODE_DEFAULT_ASSIGNEE_NAME=

# Optional explicit type IDs. If omitted, the server resolves by type name.
PINGCODE_BUG_TYPE_ID=bug
PINGCODE_REQUIREMENT_TYPE_ID=

# Safety switches.
PINGCODE_READONLY=false
PINGCODE_TIMEOUT_MS=15000

# Streamable HTTP / remote MCP transport.
PINGCODE_MCP_HOST=127.0.0.1
PINGCODE_MCP_PORT=3000
PINGCODE_MCP_AUTH_MODE=token
PINGCODE_MCP_HTTP_TOKEN=

# ChatGPT / Stytch OAuth for remote MCP.
# Set PINGCODE_MCP_PUBLIC_URL to the public HTTPS origin that serves /mcp.
# Configure this Authorization URL in Stytch Connected Apps:
#   https://your-mcp.example.com/oauth/authorize
PINGCODE_MCP_PUBLIC_URL=https://your-mcp.example.com
PINGCODE_MCP_OAUTH_RESOURCE=https://your-mcp.example.com/mcp
PINGCODE_MCP_OAUTH_RESOURCE_METADATA_URL=https://your-mcp.example.com/.well-known/oauth-protected-resource/mcp
PINGCODE_MCP_OAUTH_SCOPES_SUPPORTED=pingcode.read pingcode.write
PINGCODE_MCP_OAUTH_REQUIRED_SCOPES=pingcode.read pingcode.write
PINGCODE_MCP_OAUTH_ALLOW_STATIC_TOKEN=false
PINGCODE_MCP_STYTCH_OAUTH_DOMAIN=https://your-project.customers.stytch.com
PINGCODE_MCP_STYTCH_OAUTH_ISSUER=https://your-project.customers.stytch.com
PINGCODE_MCP_STYTCH_OAUTH_JWKS_URL=https://your-project.customers.stytch.com/.well-known/jwks.json
PINGCODE_MCP_STYTCH_OAUTH_AUDIENCE=project-live-...
PINGCODE_MCP_STYTCH_OAUTH_PROJECT_ID=
PINGCODE_MCP_STYTCH_OAUTH_SECRET=
PINGCODE_MCP_STYTCH_OAUTH_USER_ID=
PINGCODE_MCP_STYTCH_OAUTH_USER_ID_PREFIX=pingcode:
PINGCODE_MCP_STYTCH_OAUTH_USER_EMAIL=
PINGCODE_MCP_STYTCH_OAUTH_CONSENT_PASSWORD=
