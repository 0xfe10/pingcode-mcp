PINGCODE_BASE_URL=https://your-domain.pingcode.com
# Public SaaS uses https://open.pingcode.com. Private deployments may use https://your-domain/open.
PINGCODE_API_BASE_URL=https://open.pingcode.com

# Recommended for shared MCP usage: create a PingCode app with Client Credentials.
PINGCODE_CLIENT_ID=
PINGCODE_CLIENT_SECRET=

# Optional fallback: official PingCode Open API access token.
# Do not paste browser cookies or encrypted localStorage values here.
PINGCODE_ACCESS_TOKEN=
PINGCODE_AUTH_SCHEME=Bearer

PINGCODE_PROJECT_IDENTIFIER=PROJECT_KEY
PINGCODE_PROJECT_ID=

# Each user should set this to their own PingCode display name.
PINGCODE_DEFAULT_ASSIGNEE_NAME=

# Optional explicit type IDs. If omitted, the server resolves by type name.
PINGCODE_BUG_TYPE_ID=bug
PINGCODE_REQUIREMENT_TYPE_ID=

# Safety switches.
PINGCODE_READONLY=false
PINGCODE_TIMEOUT_MS=15000
