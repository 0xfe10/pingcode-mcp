{
  "name": "@succaiss/pingcode-mcp",
  "version": "0.2.0",
  "description": "MCP server for PingCode: detail, search, create, edit, status/triage, bulk, relations, comments, my-work, directory and user-mode OAuth for project work items.",
  "type": "module",
  "license": "MIT",
  "author": "succAIss",
  "homepage": "https://github.com/YOUR_GH/pingcode-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_GH/pingcode-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GH/pingcode-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pingcode",
    "project-management",
    "issue-tracker",
    "work-items",
    "bug-tracker",
    "oauth"
  ],
  "bin": {
    "pingcode-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.2.3",
    "read-excel-file": "^9.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
